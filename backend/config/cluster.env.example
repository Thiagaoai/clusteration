# Copy to config/cluster.env and edit locally.
# Do not store passwords in this file.

PVE_NODES="pve1 pve2 pve3 pve4"
PVE_NODE_IPS="10.1.10.15 10.1.10.149 10.1.10.241 10.1.10.43"
PVE_SSH_USER="root"

# Use host aliases from config/ssh_config.example, or replace with IPs if you are on the LAN.
PVE_SSH_OPTS="-F ./config/ssh_config -o BatchMode=yes -o ConnectTimeout=8"

# Backup defaults used by scripts/configure-vzdump.sh.
BACKUP_JOB_ID="local-weekly-all"
BACKUP_STORAGE="local"
BACKUP_DAYS="sun"
BACKUP_START_TIME="02:00"
BACKUP_MODE="snapshot"
BACKUP_COMPRESS="zstd"
BACKUP_RETENTION="keep-last=3"
BACKUP_ENABLED="1"
